---
---

<footer class="h-[70vh] bg-white flex flex-col justify-between px-8 md:px-16 py-16">

  <!-- Contenido principal -->
  <div class="flex flex-col md:flex-row items-start justify-between gap-12 flex-1">

    <!-- Izquierda: texto -->
    <div class="flex flex-col gap-8 justify-center flex-1 h-full">
      <h2 class="text-4xl md:text-5xl font-black text-[#1a2e3b] leading-tight" style="font-family: 'Saira', sans-serif;">
        Let's Make Something<br />Amazing Together.
      </h2>
      <p class="text-lg md:text-xl font-black text-[#1a2e3b]" style="font-family: 'Saira', sans-serif;">
        Start by <a href="#contact" class="text-[#E8603A] hover:underline transition-all">saying hi</a>
      </p>
    </div>

    <!-- Derecha: links -->
    <div class="flex flex-col gap-4 md:pt-2">
      <h3 class="font-black text-[#1a2e3b] text-lg mb-2" style="font-family: 'Saira', sans-serif;">
        Information
      </h3>
      <a href="https://github.com" target="_blank" class="text-sm text-gray-500 hover:text-[#1a2e3b] transition-colors duration-200">GitHub</a>
      <a href="https://linkedin.com" target="_blank" class="text-sm text-gray-500 hover:text-[#1a2e3b] transition-colors duration-200">LinkedIn</a>
      <a href="https://figma.com" target="_blank" class="text-sm text-gray-500 hover:text-[#1a2e3b] transition-colors duration-200">Figma</a>
      <a href="https://instagram.com" target="_blank" class="text-sm text-gray-500 hover:text-[#1a2e3b] transition-colors duration-200">Instagram</a>
    </div>

  </div>

  <!-- Separador -->
  <hr class="border-gray-200 my-6" />

  <!-- Bottom bar -->
  <div class="flex items-center justify-between gap-4">

    <!-- Logo + copyright -->
    <div class="flex items-center gap-4">
      <div class="w-10 h-10 rounded-full border-2 border-[#1a2e3b] flex items-center justify-center shrink-0">
        <img src="/img/logo.png" alt="Johan Zuluaga" class="w-full h-full object-cover rounded-full" onerror="this.style.display='none'" />
        <span class="text-[8px] font-black text-[#1a2e3b] text-center leading-tight hidden-if-img" style="font-family: 'Saira', sans-serif;">JOHAN<br/>ZULUAGA</span>
      </div>
      <span class="hidden md:block w-px h-6 bg-gray-300"></span>
      <p class="text-xs text-gray-400">© 2024. All Rights Reserved</p>
    </div>

    <!-- Crédito -->
    <p class="text-xs text-gray-400">
      Desing by <span class="font-black text-[#1a2e3b]" style="font-family: 'Saira', sans-serif;">Johan Zuluaga</span>
    </p>

  </div>

</footer>