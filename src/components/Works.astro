---
const works = [
  {
    id: 1,
    title: "App Design",
    subtitle: "Food Delivery App",
    image: "/img/works/work-1.png",
    bgColor: "#F5A623",
    webUrl: "#",
    codeUrl: "#",
  },
  {
    id: 2,
    title: "Web Design",
    subtitle: "Agency Website",
    image: "/img/works/work-2.png",
    bgColor: "#2D6A6A",
    webUrl: "#",
    codeUrl: "#",
  },
  {
    id: 3,
    title: "App Design",
    subtitle: "E-Commerce App",
    image: "/img/works/work-3.png",
    bgColor: "#F5A623",
    webUrl: "#",
    codeUrl: "#",
  },
  {
    id: 4,
    title: "Web Design",
    subtitle: "Portfolio Website",
    image: "/img/works/work-4.png",
    bgColor: "#1a2e3b",
    webUrl: "#",
    codeUrl: "#",
  },
];
---

<section id="works" class="min-h-screen bg-white flex flex-col px-8 md:px-16 py-20">

  <!-- Header -->
  <div class="works-header opacity-0 translate-y-6 flex items-start justify-between mb-6">
    <div>
      <h2 class="text-4xl md:text-5xl font-black text-[#1a2e3b]" style="font-family: 'Saira', sans-serif;">
        My Latest Works
      </h2>
      <p class="text-sm text-gray-400 mt-2">Perfect solution for digital experience</p>
    </div>
    <a href="#" class="hidden md:block text-sm font-bold text-[#E8603A] hover:underline mt-2 shrink-0">
      Explore More Works
    </a>
  </div>

  <!-- Carousel Desktop -->
  <div class="hidden md:flex flex-col gap-4">
    <div class="overflow-hidden">
      <div class="py-8 px-2">
        <div id="works-track" class="flex gap-6 transition-transform duration-500 ease-in-out select-none cursor-grab active:cursor-grabbing">
          {[...works, ...works].map((work, i) => (
            <div
              class="work-card group relative shrink-0 w-85 h-96 rounded-3xl overflow-hidden opacity-0 translate-y-8 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300"
              style={`background-color: ${work.bgColor};`}
              data-index={i % works.length}
            >
              <div class="absolute inset-0 bg-linear-to-b from-black/40 via-transparent to-black/20 z-10 rounded-3xl"></div>

              <img
                src={work.image}
                alt={work.title}
                class="absolute inset-0 w-full h-full object-cover rounded-3xl pointer-events-none"
                onerror="this.style.display='none'"
              />

              <div class="absolute top-6 left-6 z-20 transition-opacity duration-300 group-hover:opacity-0">
                <h3 class="text-white font-black text-2xl drop-shadow-lg" style="font-family: 'Saira', sans-serif;">{work.title}</h3>
                <p class="text-white/90 text-sm mt-1 drop-shadow">{work.subtitle}</p>
              </div>

              <div class="absolute inset-0 bg-[#1a2e3b]/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-3xl flex flex-col items-center justify-center gap-5 z-30">
                <div class="text-center mb-2">
                  <h3 class="text-white font-black text-xl" style="font-family: 'Saira', sans-serif;">{work.title}</h3>
                  <p class="text-white/70 text-sm">{work.subtitle}</p>
                </div>
                <a href={work.webUrl} class="flex items-center gap-3 bg-white/10 hover:bg-white/25 border border-white/40 text-white px-8 py-3 rounded-full transition-all duration-200 w-44 justify-center backdrop-blur-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                  </svg>
                  <span class="text-sm font-semibold">Web</span>
                </a>
                <a href={work.codeUrl} class="flex items-center gap-3 bg-white/10 hover:bg-white/25 border border-white/40 text-white px-8 py-3 rounded-full transition-all duration-200 w-44 justify-center backdrop-blur-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <polyline points="16 18 22 12 16 6"></polyline>
                    <polyline points="8 6 2 12 8 18"></polyline>
                  </svg>
                  <span class="text-sm font-semibold">Code</span>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Controles -->
    <div class="flex items-center justify-center gap-6">
      <button id="prev-btn" class="w-10 h-10 bg-white border border-gray-200 shadow-md rounded-full flex items-center justify-center hover:bg-gray-50 hover:shadow-lg transition-all duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#1a2e3b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div id="indicators" class="flex gap-2 items-center">
        {works.map((_, i) => (
          <button class="indicator h-2 rounded-full transition-all duration-300 bg-gray-200 w-2" data-i={i}></button>
        ))}
      </div>

      <button id="next-btn" class="w-10 h-10 bg-white border border-gray-200 shadow-md rounded-full flex items-center justify-center hover:bg-gray-50 hover:shadow-lg transition-all duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#1a2e3b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <!-- Carousel Mobile -->
  <div class="flex md:hidden flex-col gap-6">
    <div id="works-track-mobile" class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 scrollbar-hide">
      {works.map((work) => (
        <div class="group relative shrink-0 w-70 h-85 rounded-3xl overflow-hidden cursor-pointer snap-center shadow-xl"
          style={`background-color: ${work.bgColor};`}>

          <div class="absolute inset-0 bg-linear-to-b from-black/40 via-transparent to-black/20 z-10 rounded-3xl"></div>

          <img
            src={work.image}
            alt={work.title}
            class="absolute inset-0 w-full h-full object-cover rounded-3xl pointer-events-none"
            onerror="this.style.display='none'"
          />

          <div class="absolute top-5 left-5 z-20">
            <h3 class="text-white font-black text-xl drop-shadow-lg" style="font-family: 'Saira', sans-serif;">{work.title}</h3>
            <p class="text-white/90 text-sm mt-1">{work.subtitle}</p>
          </div>

          <div class="work-overlay absolute inset-0 bg-[#1a2e3b]/85 opacity-0 transition-opacity duration-300 rounded-3xl flex flex-col items-center justify-center gap-5 z-30">
            <div class="text-center mb-1">
              <h3 class="text-white font-black text-lg" style="font-family: 'Saira', sans-serif;">{work.title}</h3>
              <p class="text-white/70 text-sm">{work.subtitle}</p>
            </div>
            <a href={work.webUrl} class="flex items-center gap-3 bg-white/10 border border-white/40 text-white px-6 py-3 rounded-full justify-center w-40">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
              <span class="text-sm font-semibold">Web</span>
            </a>
            <a href={work.codeUrl} class="flex items-center gap-3 bg-white/10 border border-white/40 text-white px-6 py-3 rounded-full justify-center w-40">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <polyline points="16 18 22 12 16 6"></polyline>
                <polyline points="8 6 2 12 8 18"></polyline>
              </svg>
              <span class="text-sm font-semibold">Code</span>
            </a>
          </div>
        </div>
      ))}
    </div>

    <a href="#" class="block text-center text-sm font-bold text-[#E8603A] hover:underline">
      Explore More Works
    </a>
  </div>

</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.create({
    trigger: "#works",
    start: "top 70%",
    onEnter: () => {
      gsap.to(".works-header", { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" });
      gsap.to(".work-card", { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: "power2.out", delay: 0.2 });
    },
    onLeaveBack: () => {
      gsap.set(".works-header", { opacity: 0, y: 24 });
      gsap.set(".work-card", { opacity: 0, y: 32 });
    },
  });

  const track = document.getElementById('works-track') as HTMLElement;
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const indicators = document.querySelectorAll('.indicator');
  const totalReal = 4;
  const cardWidth = 340 + 24;
  let currentIndex = 0;

  function updateIndicators(index: number) {
    const real = ((index % totalReal) + totalReal) % totalReal;
    indicators.forEach((dot, i) => {
      const el = dot as HTMLElement;
      if (i === real) {
        el.style.width = '24px';
        el.style.backgroundColor = '#1a2e3b';
      } else {
        el.style.width = '8px';
        el.style.backgroundColor = '#e5e7eb';
      }
    });
  }

  function goTo(index: number, animate = true) {
    currentIndex = index;
    if (track) {
      track.style.transition = animate ? 'transform 0.5s ease-in-out' : 'none';
      track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
    }
    updateIndicators(currentIndex);
  }

  nextBtn?.addEventListener('click', () => {
    goTo(currentIndex + 1);
    if (currentIndex >= totalReal) {
      setTimeout(() => goTo(currentIndex - totalReal, false), 510);
    }
  });

  prevBtn?.addEventListener('click', () => {
    if (currentIndex <= 0) {
      goTo(totalReal, false);
      setTimeout(() => goTo(totalReal - 1), 20);
    } else {
      goTo(currentIndex - 1);
    }
  });

  indicators.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });

  updateIndicators(0);

  // Drag con mouse
  let isDragging = false;
  let startX = 0;
  let dragDistance = 0;

  track?.addEventListener('mousedown', (e) => {
    isDragging = true;
    startX = e.clientX;
    dragDistance = 0;
    track.style.transition = 'none';
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    dragDistance = e.clientX - startX;
    const currentOffset = currentIndex * cardWidth;
    track.style.transform = `translateX(${-currentOffset + dragDistance}px)`;
  });

  window.addEventListener('mouseup', () => {
    if (!isDragging) return;
    isDragging = false;
    if (dragDistance < -80) {
      goTo(currentIndex + 1);
      if (currentIndex >= totalReal) {
        setTimeout(() => goTo(currentIndex - totalReal, false), 510);
      }
    } else if (dragDistance > 80) {
      if (currentIndex <= 0) {
        goTo(totalReal, false);
        setTimeout(() => goTo(totalReal - 1), 20);
      } else {
        goTo(currentIndex - 1);
      }
    } else {
      goTo(currentIndex);
    }
  });

  // Tap overlay mobile
  document.querySelectorAll('#works-track-mobile .group').forEach(card => {
    card.addEventListener('click', () => {
      const overlay = card.querySelector('.work-overlay');
      if (!overlay) return;
      const isVisible = overlay.classList.contains('opacity-100');
      document.querySelectorAll('.work-overlay').forEach(o => o.classList.remove('opacity-100'));
      if (!isVisible) overlay.classList.add('opacity-100');
    });
  });
</script>