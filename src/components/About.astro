---
---

<section id="about" class="min-h-screen bg-white flex items-center px-8 md:px-16 py-20">
  <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

    <!-- Columna derecha (texto) -->
    <div class="flex flex-col gap-6 order-first md:order-last">
      <h2 class="text-4xl md:text-5xl font-black text-[#1a2e3b]" style="font-family: 'Saira', sans-serif;">
        What do i do?
      </h2>

      <div class="flex flex-col gap-4 text-sm text-gray-600 leading-loose">
        <p>
          I'm a web developer dedicated to creating digital experiences
          that are not only clear and accessible, but also engaging and
          functional for everyone.
        </p>
        <p>
          My goal is to simplify the complexity of the digital world,
          offering websites that anyone can navigate with ease.
        </p>
      </div>

      <!-- Stats -->
      <div class="flex gap-12 mt-4">
        <div class="flex flex-col">
          <span class="text-4xl font-black text-[#1a2e3b]" style="font-family: 'Saira', sans-serif;">5+</span>
          <span class="text-xs text-gray-500 mt-1">Project Completed</span>
        </div>
        <div class="flex flex-col">
          <span class="text-4xl font-black text-[#1a2e3b]" style="font-family: 'Saira', sans-serif;">3+</span>
          <span class="text-xs text-gray-500 mt-1">Happy Clients</span>
        </div>
      </div>
    </div>

    <!-- Columna izquierda (cards) -->
    <div class="flex flex-col gap-4 order-last md:order-first">

      <!-- Card Web Design -->
      <div class="about-card flex items-center gap-5 bg-white rounded-2xl shadow-md border border-gray-100 px-6 py-5 opacity-0 -translate-x-7 transition-all duration-500">
        <div class="shrink-0 w-14 h-14 rounded-full bg-[#28656C] flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
        </div>
        <div>
          <h3 class="font-bold text-[#1a2e3b] text-lg">Web Design</h3>
          <p class="text-sm text-gray-400">4 Projects</p>
        </div>
      </div>

      <!-- Card Mobile App Design -->
      <div class="about-card flex items-center gap-5 bg-white rounded-2xl shadow-md border border-gray-100 px-6 py-5 opacity-0 -translate-x-7 transition-all duration-500 delay-150">
        <div class="shrink-0 w-14 h-14 rounded-full bg-[#E8A838] flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
            <line x1="12" y1="18" x2="12.01" y2="18"></line>
          </svg>
        </div>
        <div>
          <h3 class="font-bold text-[#1a2e3b] text-lg">Mobile App Design</h3>
          <p class="text-sm text-gray-400">2 projects</p>
        </div>
      </div>

      <!-- Card Brand Identity -->
      <div class="about-card flex items-center gap-5 bg-white rounded-2xl shadow-md border border-gray-100 px-6 py-5 opacity-0 -translate-x-7 transition-all duration-500 delay-300">
        <div class="shrink-0 w-14 h-14 rounded-full bg-[#E8603A] flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
            <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
            <path d="M2 2l7.586 7.586"></path>
            <circle cx="11" cy="11" r="2"></circle>
          </svg>
        </div>
        <div>
          <h3 class="font-bold text-[#1a2e3b] text-lg">Brand Identity</h3>
          <p class="text-sm text-gray-400">40 projects</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.create({
    trigger: "#about",
    start: "top 70%",
    onEnter: () => {
      gsap.to(".about-card", {
        opacity: 1,
        x: 0,
        duration: 0.6,
        stagger: 0.15,
        ease: "power2.out",
      });
    },
    onLeaveBack: () => {
      gsap.set(".about-card", { opacity: 0, x: -30 });
    },
  });
</script>