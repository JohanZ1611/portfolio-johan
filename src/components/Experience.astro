---
const experiences = [
  {
    company: "AssetMinder",
    period: "Oct 2023 - Actuality",
    role: "Back-End",
    description: "A visual designer designs for a variety of platforms, which may include Internet and intranet sites, games, movies, kiosks and wearables. In short, they create the concepts,",
    color: "#28656C",
  },
  {
    company: "Lance",
    period: "Abr 2023 - Abr 2023",
    role: "FullStack MERN and Mobile",
    description: "A visual designer designs for a variety of platforms, which may include Internet and intranet sites, games, movies, kiosks and wearables. In short, they create the concepts,",
    color: "#E8A838",
  },
  {
    company: "Minga",
    period: "Feb 2023 - Mar 2023",
    role: "FullStack MERN",
    description: "A visual designer designs for a variety of platforms, which may include Internet and intranet sites, games, movies, kiosks and wearables. In short, they create the concepts,",
    color: "#E8603A",
  },
];
---

<section id="skills" class="min-h-screen bg-[#F8F7F1] flex flex-col items-center px-8 md:px-16 py-20">

  <!-- Título -->
  <h2 class="exp-title text-4xl md:text-5xl font-black text-[#1a2e3b] text-center mb-16 opacity-0 translate-y-6" style="font-family: 'Saira', sans-serif;">
    My Work Experience
  </h2>

  <!-- Desktop layout -->
  <div class="hidden md:flex flex-col items-center w-full max-w-4xl relative">
    {experiences.map((exp, i) => (
      <div class="exp-item opacity-0 w-full grid grid-cols-[1fr_80px_1fr] gap-4 items-center mb-20 last:mb-0">

        <!-- Izquierda: empresa y fecha -->
        <div class="text-right pr-6">
          <h3 class="font-black text-[#1a2e3b] text-xl" style="font-family: 'Saira', sans-serif;">{exp.company}</h3>
          <p class="text-sm text-gray-400 mt-1">{exp.period}</p>
        </div>

        <!-- Centro: nodo -->
        <div class="flex flex-col items-center relative">
          <!-- línea superior (excepto primer item) -->
          {i > 0 && (
            <div class="absolute bottom-full w-0 border-l-2 border-dashed border-gray-300" style="height: 80px; top: -80px;"></div>
          )}
          <div class="relative flex items-center justify-center w-14 h-14 rounded-full border-2 border-dashed z-10"
            style={`border-color: ${exp.color};`}>
            <div class="w-7 h-7 rounded-full" style={`background-color: ${exp.color};`}></div>
          </div>
          <!-- línea inferior (excepto último item) -->
          {i < experiences.length - 1 && (
            <div class="absolute top-full w-0 border-l-2 border-dashed border-gray-300" style="height: 80px;"></div>
          )}
        </div>

        <!-- Derecha: rol y descripción -->
        <div class="pl-6">
          <h3 class="font-black text-[#1a2e3b] text-xl mb-3" style="font-family: 'Saira', sans-serif;">{exp.role}</h3>
          <p class="text-sm text-gray-500 leading-loose">{exp.description}</p>
        </div>

      </div>
    ))}
  </div>

  <!-- Mobile layout -->
  <div class="flex md:hidden flex-col w-full relative">
    {experiences.map((exp, i) => (
      <div class="exp-item-mobile opacity-0 flex gap-6 mb-12 last:mb-0">

        <!-- Timeline izquierda -->
        <div class="flex flex-col items-center relative">
          <div class="relative flex items-center justify-center w-10 h-10 rounded-full border-2 border-dashed shrink-0 z-10"
            style={`border-color: ${exp.color};`}>
            <div class="w-5 h-5 rounded-full" style={`background-color: ${exp.color};`}></div>
          </div>
          {i < experiences.length - 1 && (
            <div class="flex-1 w-0 border-l-2 border-dashed border-gray-300 mt-2" style="min-height: 80px;"></div>
          )}
        </div>

        <!-- Contenido derecha -->
        <div class="flex flex-col gap-1 pt-1">
          <h3 class="font-black text-[#1a2e3b] text-lg" style="font-family: 'Saira', sans-serif;">{exp.company}</h3>
          <p class="text-xs text-gray-400">{exp.period}</p>
          <h4 class="font-black text-[#1a2e3b] text-base mt-2" style="font-family: 'Saira', sans-serif;">{exp.role}</h4>
          <p class="text-sm text-gray-500 leading-relaxed">{exp.description}</p>
        </div>

      </div>
    ))}
  </div>

</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Título
  ScrollTrigger.create({
    trigger: "#skills",
    start: "top 70%",
    onEnter: () => {
      gsap.to(".exp-title", {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
      });

      // Items desktop: alternan desde izquierda y derecha
      gsap.to(".exp-item", {
        opacity: 1,
        duration: 0.7,
        stagger: 0.25,
        ease: "power2.out",
        delay: 0.3,
      });

      // Items mobile
      gsap.to(".exp-item-mobile", {
        opacity: 1,
        x: 0,
        duration: 0.6,
        stagger: 0.2,
        ease: "power2.out",
        delay: 0.3,
      });
    },
    onLeaveBack: () => {
      gsap.set(".exp-title", { opacity: 0, y: 24 });
      gsap.set(".exp-item", { opacity: 0 });
      gsap.set(".exp-item-mobile", { opacity: 0, x: -20 });
    },
  });
</script>