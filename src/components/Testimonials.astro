  {
    id: 1,
    quote: "A complete search of the internet has found these results satisfactory result is the most popular phrase on the web. You wouldn't really say that it was satisfying",
    name: "Julian Marin",
    role: "FullStack Developer",
    avatar: "/img/testimonials/avatar-1.png",
  },
  {
    id: 2,
    quote: "A complete search of the internet has found these results satisfactory result is the most popular phrase on the web. You wouldn't really say that it was satisfying",
    name: "Julian Marin",
    role: "FullStack Developer",
    avatar: "/img/testimonials/avatar-2.png",
  },
  {
    id: 3,
    quote: "A complete search of the internet has found these results satisfactory result is the most popular phrase on the web. You wouldn't really say that it was satisfying",
    name: "Julian Marin",
    role: "FullStack Developer",
    avatar: "/img/testimonials/avatar-3.png",
  },
  {
    id: 4,
    quote: "Working with Johan was an incredible experience. His attention to detail and technical skills made our project a huge success beyond expectations.",
    name: "Maria Lopez",
    role: "Product Manager",
    avatar: "/img/testimonials/avatar-4.png",
  },
  {
    id: 5,
    quote: "Johan delivered outstanding results. The app he built for us exceeded all our expectations and our users absolutely love it.",
    name: "Carlos Ruiz",
    role: "CEO & Founder",
    avatar: "/img/testimonials/avatar-5.png",
  },
